class Solution {
    int maxSum = Integer.MIN_VALUE;

    public int maxPathSum(TreeNode root) {
        calculateGain(root);
        return maxSum;
    }

    private int calculateGain(TreeNode node) {
        if (node == null) return 0;

        // Recursively get the max gain from subtrees
        // Use Math.max(0, ...) to ignore negative paths
        int leftGain = Math.max(calculateGain(node.left), 0);
        int rightGain = Math.max(calculateGain(node.right), 0);

        // Price of a new path with the current node as the "bridge"
        int currentPathSum = node.val + leftGain + rightGain;

        // Update the global maximum
        maxSum = Math.max(maxSum, currentPathSum);

        // Return the max gain the parent can get from this node
        return node.val + Math.max(leftGain, rightGain);
    }
}
