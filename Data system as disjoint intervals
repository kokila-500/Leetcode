import java.util.*;

class SummaryRanges {

    private TreeMap<Integer, Integer> map;

    public SummaryRanges() {
        map = new TreeMap<>();
    }

    public void addNum(int val) {
        if (map.containsKey(val)) return;

        Integer left = map.floorKey(val);
        Integer right = map.ceilingKey(val);

        // Case 1: already inside an interval
        if (left != null && map.get(left) >= val) {
            return;
        }

        boolean mergeLeft = (left != null && map.get(left) + 1 == val);
        boolean mergeRight = (right != null && right - 1 == val);

        if (mergeLeft && mergeRight) {
            // merge three parts
            map.put(left, map.get(right));
            map.remove(right);
        } 
        else if (mergeLeft) {
            // extend left interval
            map.put(left, map.get(left) + 1);
        } 
        else if (mergeRight) {
            // extend right interval
            int end = map.get(right);
            map.remove(right);
            map.put(val, end);
        } 
        else {
            // new interval
            map.put(val, val);
        }
    }

    public int[][] getIntervals() {
        int[][] res = new int[map.size()][2];
        int i = 0;

        for (Map.Entry<Integer, Integer> entry : map.entrySet()) {
            res[i][0] = entry.getKey();
            res[i][1] = entry.getValue();
            i++;
        }

        return res;
    }
}
