import java.util.*;

class Solution {
    public boolean canCross(int[] stones) {
        // Map to store stone positions and the jumps that can reach them
        Map<Integer, Set<Integer>> map = new HashMap<>();
        for (int stone : stones) {
            map.put(stone, new HashSet<>());
        }
        
        // Initial state: at stone 0, the next jump must be 1 unit
        map.get(0).add(1);
        
        for (int i = 0; i < stones.length; i++) {
            int currStone = stones[i];
            Set<Integer> jumps = map.get(currStone);
            
            for (int k : jumps) {
                int nextPos = currStone + k;
                
                // If we reached the last stone
                if (nextPos == stones[stones.length - 1]) {
                    return true;
                }
                
                // If the landing position has a stone, update its jump options
                if (map.containsKey(nextPos)) {
                    if (k - 1 > 0) map.get(nextPos).add(k - 1);
                    map.get(nextPos).add(k);
                    map.get(nextPos).add(k + 1);
                }
            }
        }
        
        return false;
    }
}
