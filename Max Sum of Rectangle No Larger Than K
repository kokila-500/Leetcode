import java.util.*;

class Solution {
    public int maxSumSubmatrix(int[][] matrix, int k) {
        int rows = matrix.length;
        int cols = matrix[0].length;
        int max = Integer.MIN_VALUE;

        // Ensure outer loops are on the smaller dimension (Optimization)
        for (int l = 0; l < cols; l++) {
            int[] rowSums = new int[rows];
            for (int r = l; r < cols; r++) {
                for (int i = 0; i < rows; i++) {
                    rowSums[i] += matrix[i][r];
                }

                // Find max subarray sum <= k in 1D array rowSums
                max = Math.max(max, findMax(rowSums, k));
                if (max == k) return k; // Found the perfect match
            }
        }
        return max;
    }

    private int findMax(int[] arr, int k) {
        TreeSet<Integer> set = new TreeSet<>();
        set.add(0);
        int currSum = 0;
        int max = Integer.MIN_VALUE;

        for (int a : arr) {
            currSum += a;
            // Search for prevSum such that currSum - prevSum <= k
            // Which means prevSum >= currSum - k
            Integer prevSum = set.ceiling(currSum - k);
            if (prevSum != null) {
                max = Math.max(max, currSum - prevSum);
            }
            set.add(currSum);
        }
        return max;
    }
}
