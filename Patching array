class Solution {
    public int minPatches(int[] nums, int n) {
        long miss = 1; // smallest missing number
        int i = 0, patches = 0;

        while (miss <= n) {
            if (i < nums.length && nums[i] <= miss) {
                miss += nums[i]; // extend range
                i++;
            } else {
                // patch with miss
                miss += miss;
                patches++;
            }
        }

        return patches;
    }
}
